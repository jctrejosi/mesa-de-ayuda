# ==========================================================
# Aplicación
# ==========================================================

NODE_ENV=development
PORT=3000
APP_NAME=helpdesk-backend
APP_VERSION=1.0.0

# ==========================================================
# Base de datos
# ==========================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdesk
DB_USER=helpdesk
DB_PASSWORD=helpdesk
DATABASE_URL=mysql://helpdesk:helpdesk@localhost:3306/helpdesk

# ==========================================================
# JWT
# ==========================================================

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================================
# Seguridad
# ==========================================================

BCRYPT_ROUNDS=12

# ==========================================================
# CORS - Configuración
# ==========================================================

CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://tu-frontend.onrender.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS,HEAD
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With
CORS_EXPOSED_HEADERS=Content-Range,X-Content-Range
CORS_MAX_AGE=86400
CORS_PREFLIGHT_CONTINUE=false
CORS_OPTIONS_SUCCESS_STATUS=204

# ==========================================================
# Helmet - Configuración de seguridad
# ==========================================================

HELMET_CROSS_ORIGIN_RESOURCE_POLICY=cross-origin
HELMET_CROSS_ORIGIN_OPENER_POLICY=unsafe-none
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=false
HELMET_REFERRER_POLICY=strict-origin-when-cross-origin

# ==========================================================
# Rate limiting
# ==========================================================

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=info
LOG_PRETTY=true

# ==========================================================
# Auditoría
# ==========================================================

AUDIT_ENABLED=true

# ==========================================================
# Sentry (opcional)
# ==========================================================

SENTRY_DSN=
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ==========================================================
# Swagger
# ==========================================================

SWAGGER_ENABLED=true

# ==========================================================
# Cookies (si se utilizan)
# ==========================================================

COOKIE_SECRET=change_this_cookie_secret

# ==========================================================
# Zona horaria
# ==========================================================

TZ=America/Bogota

# ==========================================================
# Cloudinary
# ==========================================================

CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ==========================================================
# Microsoft SSO (opcional)
# ==========================================================

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ==========================================================
# Frontend URL
# ==========================================================

FRONTEND_URL=http://localhost:5173