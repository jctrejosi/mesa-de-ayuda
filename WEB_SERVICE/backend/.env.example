# ==========================================================
# Aplicación
# ==========================================================

NODE_ENV=development
PORT=3000
APP_NAME=helpdesk-backend
APP_VERSION=1.0.0

# ==========================================================
# Base de datos
# ==========================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdesk
DB_USER=helpdesk
DB_PASSWORD=helpdesk

DATABASE_URL=mysql://helpdesk:helpdesk@localhost:3306/helpdesk

# ==========================================================
# JWT
# ==========================================================

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================================
# Seguridad
# ==========================================================

BCRYPT_ROUNDS=12

# ==========================================================
# CORS
# ==========================================================

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ==========================================================
# Rate limiting
# ==========================================================

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==========================================================
# Logging
# ==========================================================

LOG_LEVEL=info
LOG_PRETTY=true

# ==========================================================
# Auditoría
# ==========================================================

AUDIT_ENABLED=true

# ==========================================================
# Sentry
# ==========================================================

SENTRY_DSN=

SENTRY_RELEASE=1.0.0

SENTRY_TRACES_SAMPLE_RATE=0.1

SENTRY_PROFILES_SAMPLE_RATE=0.1

# ==========================================================
# Swagger
# ==========================================================

SWAGGER_ENABLED=true

# ==========================================================
# Cookies (si se utilizan)
# ==========================================================

COOKIE_SECRET=change_this_cookie_secret

# ==========================================================
# Zona horaria
# ==========================================================

TZ=America/Bogota